# Runtime world state — regenerated idempotently by engine/init_world.py
world/
state/

# Python bytecode
__pycache__/
*.pyc

# Regalia / spells purchased or installed at play-time land in bin/;
# only the shop itself is tracked.
bin/*
!bin/grimoire

# Player-installed regalia configs
*.palette
hud.conf
palette

# Container build artifacts (rebuilt from container/ + the repo)
base/
dist/

# visual-plan local scratch (the plan.mdx itself IS tracked)
plan-blocks.md
plans/*/.plan-url
